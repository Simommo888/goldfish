{
  "daily_limit": 10,
  "people_limit": 5,
  "paper_limit": 5,
  "github_limit": 5,
  "product_limit": 5,
  "output_language": "zh-CN",
  "timezone": "Asia/Shanghai",
  "use_llm": true,
  "llm_provider": "deepseek",
  "llm_model": "deepseek-v4-pro",
  "llm_base_url": "https://api.deepseek.com",
  "dry_run_default": false,
  "update_dashboard": true,
  "generate_weekly_report": true,
  "enable_github_actions": true,
  "enable_notifications": false,
  "network_timeout_seconds": 10,
  "agent_step_timeout_seconds": 45,
  "agent_task_timeout_seconds": 240,
  "agent_max_total_failures": 4,
  "agent_max_consecutive_failures": 2,
  "fetch_network_in_dry_run": false,
  "enable_agent_memory": true,
  "enable_feedback_tracking": true,
  "generate_knowledge_report": true,
  "auto_create_knowledge_drafts": true,
  "draft_write_mode": "auto",
  "knowledge_report_limit": 8,
  "knowledge_min_score": 5,
  "feedback_report_limit": 10
}
